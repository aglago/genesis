{
  "id": "payments",
  "name": "Payments",
  "version": "0.1.0",
  "description": "Paystack payment initialization, verification, and webhooks",
  "npmPackage": "@genesis/payments",
  "configImport": "@genesis/payments/config",
  "configFactory": "payments",
  "envVars": [
    { "key": "PAYSTACK_SECRET_KEY", "description": "Paystack secret key", "required": true },
    { "key": "PAYSTACK_PUBLIC_KEY", "description": "Paystack public key", "required": true },
    { "key": "PAYSTACK_WEBHOOK_SECRET", "description": "Paystack webhook secret", "required": false }
  ],
  "scaffoldFiles": [
    { "source": "scaffold/payments-config.ts", "target": "lib/payments-config.ts" },
    { "source": "scaffold/initialize-route.ts", "target": "app/api/payments/initialize/route.ts" },
    { "source": "scaffold/verify-route.ts", "target": "app/api/payments/verify/route.ts" },
    { "source": "scaffold/webhook-route.ts", "target": "app/api/webhooks/paystack/route.ts" },
    { "source": "scaffold/payment-callback-page.tsx", "target": "app/payment/callback/page.tsx" },
    { "source": "scaffold/orders-page.tsx", "target": "app/(dashboard)/dashboard/orders/page.tsx" },
    {
      "source": "scaffold/dashboard-page.tsx",
      "target": "app/(dashboard)/dashboard/page.tsx",
      "overwrite": true
    }
  ]
}
